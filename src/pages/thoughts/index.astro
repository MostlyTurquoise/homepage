---
import { Image } from "astro:assets";
import { getCollection } from "astro:content";
import BaseHead from "../../components/BaseHead.astro";
import FormattedDate from "../../components/FormattedDate.astro";
import Header from "../../components/Header.astro";
import { SITE_DESCRIPTION, SITE_TITLE } from "../../consts";
import BaseTail from "../../components/BaseTail.astro";

const posts = (await getCollection("thoughts")).sort(
    (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<!doctype html>
<html lang="en">
    <head>
        <style>
            li {
                list-style-type: none;
                background-color: var(--bright-background-colour);
                margin-bottom: 1ch;
                border: 1px white solid;
                max-width: 90vw;
                width: 720px;
            }

            li:hover {
                background-color: var(--brighter-background-colour);
            }

            li a {
                width: calc(100% - 2rem);
                display: block;
                padding: 1rem;
                text-decoration: none;
                display: grid;
                grid-template-columns: 25ch auto;
                grid-template-rows: auto 2rem;
            }

            .description {
                grid-area: 1 / 2 / -1 / -1;
                /* font-family: var(--font-roboto); */
            }

            .date {
                grid-area: 2 / 1 / 3 / 2;
                margin: 0;
            }

            ul {
                padding: 0;
            }

            body {
                background-color: var(--bright-background-colour);
            }
        </style>
        <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
    </head>
    <body class="crt-filter chromatic-aberration">
        <main>
            <p>Contrary to popular belief, I have thoughts</p>
            <section>
                <ul>
                    {
                        posts.map((post) => (
                            <li>
                                <a href={`/thoughts/${post.id}/`}>
                                    <h4 class="title">{post.data.title}</h4>
                                    <p class="description">
                                        {post.data.description}
                                    </p>
                                    <p class="date">
                                        <FormattedDate
                                            date={post.data.pubDate}
                                        />
                                    </p>
                                </a>
                            </li>
                        ))
                    }
                </ul>
            </section>
            <p><a href="/skipboot">Back to homepage</a></p>
        </main>
        <BaseTail />
    </body>
</html>
